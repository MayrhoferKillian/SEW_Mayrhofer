<Window x:Class="CryptoAPI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="Crypto Price Viewer" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="10">
                <TextBox x:Name="UrlTextBox" Text="https://localhost:7045" Width="200" Margin="0,0,10,0" />
                <Button Content="Daten laden" Click="LoadButton_Click" Padding="10,5"/>
            </StackPanel>

            <lvc:CartesianChart x:Name="PriceChart" Height="300" Margin="10">
                <lvc:CartesianChart.Series>
                    <lvc:LineSeries Title="Kursverlauf" Values="{Binding PriceValues}" PointGeometrySize="5" />
                </lvc:CartesianChart.Series>
                <lvc:CartesianChart.AxisX>
                    <lvc:Axis Title="Zeit" Labels="{Binding TimeLabels}" />
                </lvc:CartesianChart.AxisX>
                <lvc:CartesianChart.AxisY>
                    <lvc:Axis Title="Preis (EUR)" />
                </lvc:CartesianChart.AxisY>
            </lvc:CartesianChart>
        </StackPanel>
    </Grid>
</Window>