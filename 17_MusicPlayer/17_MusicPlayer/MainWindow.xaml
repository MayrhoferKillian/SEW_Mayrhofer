<Window x:Class="_17_MusicPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_17_MusicPlayer"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel Margin="20">
        <ListBox x:Name="Playlist" Height="150" Margin="0,0,0,10" />

        <Button Content="Song hinzufügen" Click="AddSong_Click" Margin="0,5"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="▶ Play" Click="Play_Click" Width="80" Margin="5"/>
            <Button Content="⏹ Stop" Click="Stop_Click" Width="80" Margin="5"/>
        </StackPanel>
    </StackPanel>
</Window>
