<Window x:Class="_19_Kaffee_Konfigurator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kaffee-Konfigurator" Height="300" Width="350">
    <StackPanel Margin="20">
        <Label Content="Größe auswählen:" />
        <ComboBox SelectedValuePath="Content" SelectedValue="{Binding SelectedSize}">
            <ComboBoxItem Content="Klein" />
            <ComboBoxItem Content="Mittel" />
            <ComboBoxItem Content="Groß" />
        </ComboBox>

        <CheckBox Content="Extra Schuss Espresso" 
                  IsChecked="{Binding IsExtraShot}" Margin="0,15" />

        <StackPanel Orientation="Horizontal" Margin="0,10">
            <TextBlock Text="Gesamtpreis: " FontWeight="Bold" />
            <TextBlock Text="{Binding TotalPrice, StringFormat='{}{0:C}'}" />
        </StackPanel>

        <Button Content="Bestellen" Command="{Binding OrderCommand}" Height="30" />
    </StackPanel>
</Window>